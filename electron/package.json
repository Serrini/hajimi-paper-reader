{
  "name": "hajimi-paper-reader",
  "version": "1.0.0",
  "description": "Hajimi Paper Reader desktop app for local-first paper reading",
  "main": "main.js",
  "author": "Hajimi Paper Reader",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:frontend\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:frontend": "cd ../frontend && npm start",
    "build:frontend": "cd ../frontend && npm run build",
    "build:backend": "node ../scripts/build-backend.js",
    "dist": "node ../scripts/dist.js",
    "dist:win": "node ../scripts/dist.js --win",
    "dist:mac": "node ../scripts/dist.js --mac",
    "dist:linux": "node ../scripts/dist.js --linux"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.imem.paperreader",
    "productName": "Hajimi Paper Reader",
    "copyright": "Copyright © 2025 Hajimi Paper Reader",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "utils/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/build-desktop",
        "to": "frontend/build",
        "filter": ["**/*"]
      },
      {
        "from": "../backend/dist/imem_studio",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
